{
  "name": "api",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "predev": "npm run prisma:generate:safe",
    "pretest": "npm run prisma:generate",
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "preflight:env": "node scripts/preflight-env.cjs",
    "start:prod": "npm run preflight:env && node src/index.js",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:generate:safe": "prisma generate --schema prisma/schema.prisma || echo prisma generate skipped due to local file lock",
    "prisma:seed": "node prisma/seed.js",
    "prisma:migrate:dev": "prisma migrate dev --schema prisma/schema.prisma",
    "prisma:migrate:deploy": "prisma migrate deploy --schema prisma/schema.prisma",
    "test": "node --test tests/integration/**/*.test.js"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@prisma/adapter-pg": "^6.19.3",
    "@prisma/client": "^6.19.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "ldapjs": "^3.0.7",
    "pg": "^8.20.0",
    "prisma": "^6.19.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.14",
    "supertest": "^7.1.1"
  }
}
