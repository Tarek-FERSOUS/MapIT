PORT=3002
NODE_ENV=production
JWT_SECRET=replace-with-a-strong-random-secret
DEV_MODE=false

# Active Directory / LDAP
AD_URL=ldap://ad.company.local
AD_DOMAIN=company.local
DN_BASE=dc=company,dc=local
BIND_DN=cn=svc-mapit,ou=ServiceAccounts,dc=company,dc=local

# Comma-separated allow list for browser/API access, for example:
# CORS_ORIGIN=https://mapit.company.com,https://mapit-admin.company.com
CORS_ORIGIN=https://mapit.company.com

ADMIN_USERNAMES=admin.user

# Primary DB endpoint for writes and current Prisma operations
DATABASE_URL=postgresql://appuser:strong-password@10.10.10.10:5432/itdocs

# Reserved for future read-only traffic routing to replica
# DATABASE_READ_URL=postgresql://appuser:strong-password@10.10.10.11:5432/itdocs
